<%- include("partials/header") %>

<%- include("partials/navbar") %>

<div class="form-container">

    <div class="form-box">

        <h2>Report Lost Item</h2>

        <form action="/add-lost" method="POST">

            <div class="form-group">

                <label>Item Name</label>

                <input
                    class="form-control"
                    type="text"
                    name="title"
                    required>

            </div>

            <div class="form-group">

                <label>Category</label>

                <input
                    class="form-control"
                    type="text"
                    name="category"
                    required>

            </div>

            <div class="form-group">

                <label>Description</label>

                <textarea
                    class="form-control"
                    name="description"
                    rows="4"
                    required></textarea>

            </div>

            <div class="form-group">

                <label>Location</label>

                <input
                    class="form-control"
                    type="text"
                    name="location"
                    required>

            </div>

            <button class="btn-submit">

                Submit

            </button>

        </form>

    </div>

</div>

<%- include("partials/footer") %>