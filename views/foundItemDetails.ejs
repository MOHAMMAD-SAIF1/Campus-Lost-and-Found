<%- include("partials/header") %>

<%- include("partials/navbar") %>

<div class="container py-5">

    <div class="row">

        <!-- Image -->

        <div class="col-lg-5 mb-4">

            <div class="card shadow border-0">

                <img
                    src="/uploads/<%= item.image %>"
                    class="card-img-top"
                    style="height:450px; object-fit:cover;"
                    alt="Found Item">

                <div class="card-body text-center">

                    <span class="badge bg-success fs-6">

                        📦 Found Item

                    </span>

                </div>

            </div>

        </div>

        <!-- Details -->

        <div class="col-lg-7">

            <div class="card shadow border-0">

                <div class="card-body">

                    <h2 class="fw-bold mb-3">

                        <%= item.title %>

                    </h2>

                    <hr>

                    <div class="row mb-3">

                        <div class="col-md-6">

                            <h6 class="text-muted">

                                Category

                            </h6>

                            <span class="badge bg-primary fs-6">

                                <%= item.category %>

                            </span>

                        </div>

                        <div class="col-md-6">

                            <h6 class="text-muted">

                                Status

                            </h6>

                            <% if(item.status==="Found"){ %>

                                <span class="badge bg-success fs-6">

                                    Found

                                </span>

                            <% } else { %>

                                <span class="badge bg-warning text-dark fs-6">

                                    Returned

                                </span>

                            <% } %>

                        </div>

                    </div>

                    <hr>

                    <h5>

                        Description

                    </h5>

                    <p>

                        <%= item.description %>

                    </p>

                    <hr>

                    <h5>

                        Location

                    </h5>

                    <p>

                        <i class="bi bi-geo-alt-fill text-danger"></i>

                        <%= item.location %>

                    </p>

                    <hr>

                    <h5>

                        Date Found

                    </h5>

                    <p>

                        <i class="bi bi-calendar-event"></i>

                        <%= item.found_date %>

                    </p>

                    <hr>

                    <!-- AI Ready -->

                    <div class="alert alert-success">

                        <h5>

                            🤖 AI Smart Analysis

                        </h5>

                        <ul class="mb-0">

                            <li>Image successfully uploaded.</li>

                            <li>Category identified.</li>

                            <li>Ready for Gemini AI similarity matching.</li>

                            <li>Confidence Score will appear here after AI integration.</li>

                        </ul>

                    </div>

                    <div class="d-grid gap-2 mt-4">

                        <a
                            href="/found-items"
                            class="btn btn-secondary">

                            <i class="bi bi-arrow-left"></i>

                            Back to Found Items

                        </a>

                        <% if(user && (user.id===item.user_id || user.role==="admin")){ %>

                            <a
                                href="/edit-found/<%= item.id %>"
                                class="btn btn-warning">

                                <i class="bi bi-pencil-square"></i>

                                Edit Item

                            </a>

                        <% } %>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<%- include("partials/footer") %>