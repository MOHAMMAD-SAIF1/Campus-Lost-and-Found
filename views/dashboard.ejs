<%- include("partials/header") %>
<%- include("partials/navbar") %>

<div class="container">

    <div class="dashboard-header">

        <h1>Welcome, <%= user.full_name %> 👋</h1>

        <p>
            Manage your lost and found items from one place.
        </p>

    </div>

    <div class="dashboard-cards">

        <div class="card">

            <h3>Total Users</h3>

            <h2><%= totalUsers %></h2>

        </div>

        <div class="card">

            <h3>Lost Items</h3>

            <h2><%= totalLost %></h2>

        </div>

        <div class="card">

            <h3>Found Items</h3>

            <h2><%= totalFound %></h2>

        </div>

    </div>

    <div class="dashboard-actions">

        <a href="/add-lost" class="btn-primary">
            Report Lost Item
        </a>

        <a href="/add-found" class="btn-primary">
            Report Found Item
        </a>

    </div>

    <div class="recent-section">

        <h2>Recent Lost Items</h2>

        <% if(recentItems.length === 0){ %>

            <p>No lost items have been reported yet.</p>

        <% } else { %>

            <% recentItems.forEach(item => { %>

                <div class="feature-card">

                    <img
                        src="/uploads/<%= item.image %>"
                        class="item-image"
                        alt="Item Image">

                    <h3><%= item.title %></h3>

                    <p>

                        <strong>Category:</strong>

                        <%= item.category %>

                    </p>

                    <p>

                        <strong>Location:</strong>

                        <%= item.location %>

                    </p>

                    <p>

                        <strong>Status:</strong>

                        <%= item.status %>

                    </p>

                </div>

                <br>

            <% }) %>

        <% } %>

    </div>

</div>

<%- include("partials/footer") %>