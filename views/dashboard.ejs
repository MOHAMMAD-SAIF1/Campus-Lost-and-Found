<%- include("partials/header") %>
<%- include("partials/navbar") %>

<div class="container py-5">

    <!-- Welcome Section -->
    <div class="text-center mb-5">

        <h1 class="fw-bold">
            Welcome, <%= user.full_name %> 👋
        </h1>

        <p class="text-muted fs-5">
            Manage your lost and found activities from your personal dashboard.
        </p>

    </div>

    <!-- Statistics Cards -->
    <div class="row g-4 mb-5">

        <div class="col-md-4">

            <div class="card shadow border-0 text-center h-100">

                <div class="card-body">

                    <i class="bi bi-people-fill display-3 text-primary"></i>

                    <h4 class="mt-3">
                        Total Users
                    </h4>

                    <h2 class="fw-bold">
                        <%= totalUsers %>
                    </h2>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow border-0 text-center h-100">

                <div class="card-body">

                    <i class="bi bi-search display-3 text-danger"></i>

                    <h4 class="mt-3">
                        Lost Items
                    </h4>

                    <h2 class="fw-bold">
                        <%= totalLost %>
                    </h2>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow border-0 text-center h-100">

                <div class="card-body">

                    <i class="bi bi-box-seam display-3 text-success"></i>

                    <h4 class="mt-3">
                        Found Items
                    </h4>

                    <h2 class="fw-bold">
                        <%= totalFound %>
                    </h2>

                </div>

            </div>

        </div>

    </div>

    <!-- Quick Actions -->

    <div class="card shadow border-0 mb-5">

        <div class="card-body">

            <h3 class="mb-4">

                Quick Actions

            </h3>

            <a href="/add-lost" class="btn btn-danger me-2 mb-2">

                <i class="bi bi-search"></i>

                Report Lost Item

            </a>

            <a href="/add-found" class="btn btn-success me-2 mb-2">

                <i class="bi bi-box-seam"></i>

                Report Found Item

            </a>

            <a href="/profile" class="btn btn-primary mb-2">

                <i class="bi bi-person-circle"></i>

                My Profile

            </a>

        </div>

    </div>

    <!-- Information Banner -->

    <div class="alert alert-info shadow-sm mb-5">

        <h5>

            📢 Dashboard Overview

        </h5>

        <p class="mb-0">

            View recent lost items, report new items, browse found items,
            manage your profile, and keep track of your claims.

        </p>

    </div>

    <!-- Recent Lost Items -->

    <h2 class="mb-4">

        Recent Lost Items

    </h2>

    <% if(recentItems.length===0){ %>

        <div class="alert alert-warning">

            No lost items have been reported yet.

        </div>

    <% } else { %>

        <div class="row">

            <% recentItems.forEach(item=>{ %>

                <div class="col-md-4 mb-4">

                    <div class="card shadow border-0 h-100">

                        <img

                            src="/uploads/<%= item.image %>"

                            class="card-img-top"

                            style="height:220px; object-fit:cover;"

                            alt="Item Image">

                        <div class="card-body">

                            <h4 class="card-title">

                                <%= item.title %>

                            </h4>

                            <p>

                                <strong>Category:</strong>

                                <span class="badge bg-primary">

                                    <%= item.category %>

                                </span>

                            </p>

                            <p>

                                <strong>Location:</strong>

                                <%= item.location %>

                            </p>

                            <p>

                                <strong>Status:</strong>

                                <% if(item.status==="Lost"){ %>

                                    <span class="badge bg-danger">

                                        Lost

                                    </span>

                                <% } else { %>

                                    <span class="badge bg-success">

                                        Returned

                                    </span>

                                <% } %>

                            </p>

                        </div>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } %>

</div>

<%- include("partials/footer") %>