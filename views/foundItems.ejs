<%- include("partials/header") %>

<%- include("partials/navbar") %>

<div class="container">

<form action="/search-found" method="GET">

    <input
        class="form-control"
        type="text"
        name="keyword"
        value="<%= typeof keyword !== 'undefined' ? keyword : '' %>"
        placeholder="Search by item, category or location">

    <br>

    <button class="btn-submit">
        Search
    </button>

</form>

<br>

<h1>Found Items</h1>

<a class="btn-primary" href="/add-found">
    + Report Found Item
</a>

<br><br>

<% if(items.length===0){ %>

<h3>No Found Items Available</h3>

<% } else { %>

<% items.forEach(item=>{ %>

<div class="feature-card">

<img
    src="/uploads/<%= item.image %>"
    alt="Item Image"
    class="item-image">

<h2><%= item.title %></h2>

<p>
<strong>Category:</strong>
<%= item.category %>
</p>

<p>
<strong>Description:</strong>
<%= item.description %>
</p>

<p>
<strong>Location:</strong>
<%= item.location %>
</p>

<p>
<strong>Status:</strong>
<%= item.status %>
</p>

<p>
<strong>Reported By:</strong>
<%= item.full_name %>
</p>

<br>

<a
class="btn-primary"
href="/edit-found/<%= item.id %>">
Edit
</a>

&nbsp;

<a
class="btn-primary"
href="/delete-found/<%= item.id %>">
Delete
</a>

</div>

<br>

<% }) %>

<% } %>

</div>

<%- include("partials/footer") %>