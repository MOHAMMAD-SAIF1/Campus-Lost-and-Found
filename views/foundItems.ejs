<%- include("partials/header") %>
<%- include("partials/navbar") %>

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold">
                📦 Found Items
            </h1>

            <p class="text-muted">
                Browse all found items reported across the campus.
            </p>

        </div>

        <a href="/add-found" class="btn btn-success">

            <i class="bi bi-plus-circle"></i>

            Report Found Item

        </a>

    </div>

    <!-- Search -->

    <div class="card shadow-sm border-0 mb-5">

        <div class="card-body">

            <form action="/search-found" method="GET">

                <div class="row">

                    <div class="col-md-10">

                        <input
                            type="text"
                            class="form-control"
                            name="keyword"
                            value="<%= typeof keyword !== 'undefined' ? keyword : '' %>"
                            placeholder="Search by item, category or location">

                    </div>

                    <div class="col-md-2 d-grid">

                        <button class="btn btn-primary">

                            <i class="bi bi-search"></i>

                            Search

                        </button>

                    </div>

                </div>

            </form>

        </div>

    </div>

    <% if(items.length===0){ %>

        <div class="alert alert-warning text-center">

            <h5>No Found Items Available</h5>

        </div>

    <% } else { %>

        <div class="row">

            <% items.forEach(item=>{ %>

                <div class="col-lg-4 col-md-6 mb-4">

                    <div class="card shadow border-0 h-100">

                        <img
                            src="/uploads/<%= item.image %>"
                            class="card-img-top"
                            style="height:240px;object-fit:cover;"
                            alt="Found Item">

                        <div class="card-body">

                            <div class="d-flex justify-content-between align-items-center">

                                <h4 class="fw-bold mb-0">

                                    <%= item.title %>

                                </h4>

                                <span class="badge bg-success">

                                    <%= item.category %>

                                </span>

                            </div>

                            <hr>

                            <p>

                                <strong>Description</strong>

                                <br>

                                <%= item.description %>

                            </p>

                            <p>

                                <i class="bi bi-geo-alt-fill text-danger"></i>

                                <strong> Location</strong>

                                <br>

                                <%= item.location %>

                            </p>

                            <p>

                                <i class="bi bi-person-fill text-primary"></i>

                                <strong> Reported By</strong>

                                <br>

                                <%= item.full_name %>

                            </p>

                            <p>

                                <strong>Status</strong>

                                <br>

                                <% if(item.status==="Found"){ %>

                                    <span class="badge bg-primary">

                                        📦 Found

                                    </span>

                                <% } else { %>

                                    <span class="badge bg-success">

                                        ✅ Returned

                                    </span>

                                <% } %>

                            </p>

                            <!-- Future AI Integration -->

                            <div class="alert alert-success">

                                🤖 <strong>AI Status</strong>

                                <br>

                                Ready for Smart Matching

                            </div>

                        </div>

                        <div class="card-footer bg-white">

                            <div class="d-grid gap-2">

                                <a
                                    href="/found-item/<%= item.id %>"
                                    class="btn btn-outline-primary">

                                    <i class="bi bi-eye-fill"></i>

                                    View Details

                                </a>

                                <% if(item.user_id === user.id || user.role === "admin"){ %>

                                    <a
                                        href="/edit-found/<%= item.id %>"
                                        class="btn btn-warning">

                                        <i class="bi bi-pencil-square"></i>

                                        Edit

                                    </a>

                                    <a
                                        href="/delete-found/<%= item.id %>"
                                        class="btn btn-danger"
                                        onclick="return confirm('Delete this item?')">

                                        <i class="bi bi-trash-fill"></i>

                                        Delete

                                    </a>

                                <% } %>

                            </div>

                        </div>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } %>

</div>

<%- include("partials/footer") %>