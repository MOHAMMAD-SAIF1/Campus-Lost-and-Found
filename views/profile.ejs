<%- include("partials/header") %>

<%- include("partials/navbar") %>

<div class="container py-5">

    <div class="row justify-content-center">

        <!-- Profile Card -->

        <div class="col-lg-4 mb-4">

            <div class="card shadow border-0">

                <div class="card-body text-center">

                    <img
                        src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(user.full_name) %>&background=0D6EFD&color=fff&size=200"
                        class="rounded-circle shadow mb-3"
                        width="150"
                        height="150"
                        alt="Profile">

                    <h3 class="fw-bold">

                        <%= user.full_name %>

                    </h3>

                    <p class="text-muted">

                        <%= user.email %>

                    </p>

                    <% if(user.role==="admin"){ %>

                        <span class="badge bg-danger fs-6">

                            👑 Administrator

                        </span>

                    <% } else { %>

                        <span class="badge bg-success fs-6">

                            🎓 Student

                        </span>

                    <% } %>

                    <hr>

                    <p>

                        <i class="bi bi-telephone-fill text-primary"></i>

                        <%= user.phone || "Not Updated" %>

                    </p>

                </div>

            </div>

        </div>

        <!-- Update Profile -->

        <div class="col-lg-8">

            <div class="card shadow border-0">

                <div class="card-header bg-primary text-white">

                    <h3 class="mb-0">

                        ✏️ Update Profile

                    </h3>

                </div>

                <div class="card-body">

                    <form action="/profile" method="POST">

                        <div class="mb-3">

                            <label class="form-label">

                                Full Name

                            </label>

                            <input

                                type="text"

                                class="form-control"

                                name="full_name"

                                value="<%= user.full_name %>"

                                required>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">

                                Email Address

                            </label>

                            <input

                                type="email"

                                class="form-control"

                                value="<%= user.email %>"

                                readonly>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">

                                Phone Number

                            </label>

                            <input

                                type="text"

                                class="form-control"

                                name="phone"

                                value="<%= user.phone %>">

                        </div>

                        <div class="d-grid">

                            <button

                                class="btn btn-primary btn-lg"

                                type="submit">

                                <i class="bi bi-check-circle-fill"></i>

                                Update Profile

                            </button>

                        </div>

                    </form>

                </div>

            </div>

            <br>

            <!-- Account Information -->

            <div class="card shadow border-0">

                <div class="card-header bg-dark text-white">

                    <h4 class="mb-0">

                        📊 Account Information

                    </h4>

                </div>

                <div class="card-body">

                    <div class="row text-center">

                        <div class="col-md-4">

                            <h2 class="text-primary">

                                <i class="bi bi-person-circle"></i>

                            </h2>

                            <h6>User ID</h6>

                            <strong>#<%= user.id %></strong>

                        </div>

                        <div class="col-md-4">

                            <h2 class="text-success">

                                <i class="bi bi-shield-check"></i>

                            </h2>

                            <h6>Role</h6>

                            <strong>

                                <%= user.role %>

                            </strong>

                        </div>

                        <div class="col-md-4">

                            <h2 class="text-warning">

                                <i class="bi bi-envelope-fill"></i>

                            </h2>

                            <h6>Status</h6>

                            <strong class="text-success">

                                Active

                            </strong>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<%- include("partials/footer") %>