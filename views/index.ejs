<!-- Hero Section -->
<section class="bg-primary text-white py-5">

    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-6">

                <h1 class="display-4 fw-bold">
                    🎒 Campus Lost & Found Platform
                </h1>

                <p class="lead mt-3">
                    A secure platform that helps students report lost items,
                    find belongings, connect with finders, and recover valuables
                    quickly through smart matching.
                </p>

                <div class="mt-4">

                    <a href="/add-lost" class="btn btn-light btn-lg me-3">
                        Report Lost Item
                    </a>

                    <a href="/add-found" class="btn btn-warning btn-lg">
                        Report Found Item
                    </a>

                </div>

            </div>

            <div class="col-lg-6 text-center">

                <img src="/images/lostfound.jpg"
                     class="img-fluid"
                     style="max-height:350px;"
                     alt="Campus Lost and Found">

            </div>

        </div>

    </div>

</section>

