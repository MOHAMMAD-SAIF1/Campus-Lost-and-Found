<%- include("partials/header") %>

<%- include("partials/navbar") %>

<div class="container py-5">

    <div class="text-center mb-5">

        <h1 class="fw-bold">

            📋 Claim Requests

        </h1>

        <p class="text-muted">

            Review, approve or reject ownership claims submitted by users.

        </p>

    </div>

    <% if(claims.length===0){ %>

        <div class="alert alert-info text-center">

            <h4>

                😊 No Claim Requests Available

            </h4>

        </div>

    <% } else { %>

        <div class="row">

            <% claims.forEach(claim=>{ %>

                <div class="col-lg-6 mb-4">

                    <div class="card shadow border-0 h-100">

                        <div class="card-header bg-primary text-white">

                            <h4 class="mb-0">

                                <i class="bi bi-box-seam-fill"></i>

                                <%= claim.title %>

                            </h4>

                        </div>

                        <div class="card-body">

                            <p>

                                <strong>

                                    <i class="bi bi-person-fill text-primary"></i>

                                    Requested By

                                </strong>

                                <br>

                                <%= claim.full_name %>

                            </p>

                            <hr>

                            <p>

                                <strong>

                                    <i class="bi bi-file-earmark-text-fill text-success"></i>

                                    Ownership Proof

                                </strong>

                            </p>

                            <div class="alert alert-light border">

                                <%= claim.proof %>

                            </div>

                            <p>

                                <strong>

                                    <i class="bi bi-shield-check"></i>

                                    Status

                                </strong>

                                <br>

                                <% if(claim.status==="Pending"){ %>

                                    <span class="badge bg-warning text-dark fs-6">

                                        ⏳ Pending Review

                                    </span>

                                <% } %>

                                <% if(claim.status==="Approved"){ %>

                                    <span class="badge bg-success fs-6">

                                        ✅ Approved

                                    </span>

                                <% } %>

                                <% if(claim.status==="Rejected"){ %>

                                    <span class="badge bg-danger fs-6">

                                        ❌ Rejected

                                    </span>

                                <% } %>

                            </p>

                            <hr>

                            <div class="alert alert-info">

                                <strong>

                                    🤖 AI Recommendation

                                </strong>

                                <br><br>

                                <% if(claim.status==="Pending"){ %>

                                    This claim is waiting for administrator verification.

                                <% } else if(claim.status==="Approved"){ %>

                                    Ownership verified successfully.

                                <% } else { %>

                                    Ownership could not be verified.

                                <% } %>

                            </div>

                        </div>

                        <% if(claim.status==="Pending"){ %>

                            <div class="card-footer bg-white">

                                <div class="d-grid gap-2">

                                    <a

                                        href="/approve-claim/<%= claim.id %>"

                                        class="btn btn-success">

                                        <i class="bi bi-check-circle-fill"></i>

                                        Approve Claim

                                    </a>

                                    <a

                                        href="/reject-claim/<%= claim.id %>"

                                        class="btn btn-danger">

                                        <i class="bi bi-x-circle-fill"></i>

                                        Reject Claim

                                    </a>

                                </div>

                            </div>

                        <% } %>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } %>

</div>

<%- include("partials/footer") %>