<%- include("partials/header") %>

<%- include("partials/navbar") %>

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-success text-white text-center py-4 rounded-top-4">

                    <h2 class="fw-bold mb-0">

                        <i class="bi bi-pencil-square"></i>

                        Edit Found Item

                    </h2>

                    <small>

                        Update the details of your found item.

                    </small>

                </div>

                <div class="card-body p-4">

                    <form
                        action="/edit-found/<%= item.id %>"
                        method="POST"
                        enctype="multipart/form-data">

                        <!-- Current Image -->

                        <div class="text-center mb-4">

                            <img
                                src="/uploads/<%= item.image %>"
                                class="img-fluid rounded shadow"
                                style="width:260px;height:260px;object-fit:cover;"
                                alt="Found Item">

                        </div>

                        <!-- Upload -->

                        <div class="mb-4">

                            <label class="form-label fw-bold">

                                Change Image

                            </label>

                            <input
                                type="file"
                                name="image"
                                class="form-control"
                                accept="image/*">

                        </div>

                        <!-- Title -->

                        <div class="mb-3">

                            <label class="form-label fw-bold">

                                Item Name

                            </label>

                            <input
                                type="text"
                                name="title"
                                class="form-control"
                                value="<%= item.title %>"
                                required>

                        </div>

                        <!-- Category -->

                        <div class="mb-3">

                            <label class="form-label fw-bold">

                                Category

                            </label>

                            <select
                                name="category"
                                class="form-select"
                                required>

                                <option <%= item.category==="Laptop"?"selected":"" %>>Laptop</option>

                                <option <%= item.category==="Mobile"?"selected":"" %>>Mobile</option>

                                <option <%= item.category==="Wallet"?"selected":"" %>>Wallet</option>

                                <option <%= item.category==="ID Card"?"selected":"" %>>ID Card</option>

                                <option <%= item.category==="Bag"?"selected":"" %>>Bag</option>

                                <option <%= item.category==="Keys"?"selected":"" %>>Keys</option>

                                <option <%= item.category==="Watch"?"selected":"" %>>Watch</option>

                                <option <%= item.category==="Books"?"selected":"" %>>Books</option>

                                <option <%= item.category==="Other"?"selected":"" %>>Other</option>

                            </select>

                        </div>

                        <!-- Description -->

                        <div class="mb-3">

                            <label class="form-label fw-bold">

                                Description

                            </label>

                            <textarea
                                name="description"
                                rows="5"
                                class="form-control"
                                required><%= item.description %></textarea>

                        </div>

                        <!-- Location -->

                        <div class="mb-4">

                            <label class="form-label fw-bold">

                                Found Location

                            </label>

                            <input
                                type="text"
                                name="location"
                                class="form-control"
                                value="<%= item.location %>"
                                required>

                        </div>

                        <!-- AI -->

                        <div class="alert alert-success">

                            <h5>

                                🤖 AI Ready

                            </h5>

                            <p class="mb-0">

                                After updating this item, the AI Smart Matching engine
                                will automatically use the latest details for future
                                similarity matching.

                            </p>

                        </div>

                        <!-- Buttons -->

                        <div class="d-grid gap-2 mt-4">

                            <button
                                type="submit"
                                class="btn btn-success btn-lg">

                                <i class="bi bi-check-circle-fill"></i>

                                Update Found Item

                            </button>

                            <a
                                href="/found-items"
                                class="btn btn-outline-secondary btn-lg">

                                <i class="bi bi-arrow-left"></i>

                                Cancel

                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

<%- include("partials/footer") %>