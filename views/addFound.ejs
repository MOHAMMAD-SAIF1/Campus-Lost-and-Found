<%- include("partials/header") %>

<%- include("partials/navbar") %>

<div class="container py-5">

    <div class="row justify-content-center align-items-center">

        <!-- Left Side -->

        <div class="col-lg-5 d-none d-lg-block">

            <div class="text-center">

                <img
                    src="/images/lostfound.jpg"
                    class="img-fluid rounded shadow"
                    alt="Found Item">

                <h2 class="mt-4 fw-bold">

                    Found Something?

                </h2>

                <p class="text-muted">

                    Help someone recover their belongings by reporting the found
                    item with accurate details.

                </p>

            </div>

        </div>

        <!-- Form -->

        <div class="col-lg-7">

            <div class="card shadow-lg border-0">

                <div class="card-header bg-success text-white text-center py-4">

                    <h2>

                        <i class="bi bi-search-heart-fill"></i>

                        Report Found Item

                    </h2>

                    <p class="mb-0">

                        Provide complete information about the found item.

                    </p>

                </div>

                <div class="card-body p-5">

                    <form action="/add-found" method="POST">

                        <div class="mb-3">

                            <label class="form-label">

                                Item Name

                            </label>

                            <div class="input-group">

                                <span class="input-group-text">

                                    <i class="bi bi-box-seam-fill"></i>

                                </span>

                                <input

                                    type="text"

                                    class="form-control"

                                    name="title"

                                    placeholder="e.g. iPhone 15"

                                    required>

                            </div>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">

                                Category

                            </label>

                            <div class="input-group">

                                <span class="input-group-text">

                                    <i class="bi bi-grid-fill"></i>

                                </span>

                                <select

                                    class="form-select"

                                    name="category"

                                    required>

                                    <option value="">Select Category</option>
                                    <option>Laptop</option>
                                    <option>Mobile</option>
                                    <option>Wallet</option>
                                    <option>ID Card</option>
                                    <option>Bag</option>
                                    <option>Keys</option>
                                    <option>Watch</option>
                                    <option>Books</option>
                                    <option>Other</option>

                                </select>

                            </div>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">

                                Description

                            </label>

                            <textarea

                                class="form-control"

                                rows="5"

                                name="description"

                                placeholder="Describe the found item in detail..."

                                required></textarea>

                        </div>

                        <div class="mb-4">

                            <label class="form-label">

                                Found Location

                            </label>

                            <div class="input-group">

                                <span class="input-group-text">

                                    <i class="bi bi-geo-alt-fill"></i>

                                </span>

                                <input

                                    type="text"

                                    class="form-control"

                                    name="location"

                                    placeholder="e.g. Cafeteria"

                                    required>

                            </div>

                        </div>

                        <div class="d-grid">

                            <button

                                type="submit"

                                class="btn btn-success btn-lg">

                                <i class="bi bi-check-circle-fill"></i>

                                Report Found Item

                            </button>

                        </div>

                    </form>

                </div>

                <div class="card-footer bg-light text-center">

                    Thank you for helping reunite lost belongings with their owners.

                    ❤️

                </div>

            </div>

        </div>

    </div>

</div>

<%- include("partials/footer") %>