<%- include("partials/header") %>

<%- include("partials/navbar") %>

<div class="form-container">

    <div class="form-box">

        <h2>Login</h2>

        <form action="/login" method="POST">

            <div class="form-group">

                <label>Email</label>

                <input
                    class="form-control"
                    type="email"
                    name="email"
                    required>

            </div>

            <div class="form-group">

                <label>Password</label>

                <input
                    class="form-control"
                    type="password"
                    name="password"
                    required>

            </div>

            <button class="btn-submit">
                Login
            </button>

        </form>

        <div class="form-link">

            Don't have an account?

            <a href="/register">
                Register
            </a>

        </div>

    </div>

</div>

<%- include("partials/footer") %>