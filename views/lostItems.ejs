<%- include("partials/header") %>
<%- include("partials/navbar") %>

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold">
                🎒 Lost Items
            </h1>

            <p class="text-muted">
                Browse all reported lost items on campus.
            </p>

        </div>

        <a href="/add-lost" class="btn btn-danger">

            <i class="bi bi-plus-circle"></i>

            Report Lost Item

        </a>

    </div>

    <!-- Search -->

    <div class="card shadow-sm border-0 mb-5">

        <div class="card-body">

            <form action="/search-lost" method="GET">

                <div class="row">

                    <div class="col-md-10">

                        <input
                            type="text"
                            class="form-control"
                            name="keyword"
                            value="<%= typeof keyword !== 'undefined' ? keyword : '' %>"
                            placeholder="Search by title, category or location">

                    </div>

                    <div class="col-md-2 d-grid">

                        <button class="btn btn-primary">

                            <i class="bi bi-search"></i>

                            Search

                        </button>

                    </div>

                </div>

            </form>

        </div>

    </div>

    <% if(items.length===0){ %>

        <div class="alert alert-warning">

            No Lost Items Found.

        </div>

    <% } else { %>

        <div class="row">

            <% items.forEach(item=>{ %>

                <div class="col-lg-4 col-md-6 mb-4">

                    <div class="card shadow h-100 border-0">

                        <img
                            src="/uploads/<%= item.image %>"
                            class="card-img-top"
                            style="height:240px; object-fit:cover;"
                            alt="Item">

                        <div class="card-body">

                            <h4 class="fw-bold">

                                <%= item.title %>

                            </h4>

                            <p>

                                <span class="badge bg-primary">

                                    <%= item.category %>

                                </span>

                            </p>

                            <p>

                                <strong>Description</strong><br>

                                <%= item.description %>

                            </p>

                            <p>

                                <i class="bi bi-geo-alt-fill text-danger"></i>

                                <%= item.location %>

                            </p>

                            <p>

                                <i class="bi bi-person-fill text-primary"></i>

                                <%= item.full_name %>

                            </p>

                            <p>

                                <strong>Status:</strong>

                                <% if(item.status==="Lost"){ %>

                                    <span class="badge bg-danger">

                                        Lost

                                    </span>

                                <% } else { %>

                                    <span class="badge bg-success">

                                        Returned

                                    </span>

                                <% } %>

                            </p>

                        </div>

                        <div class="card-footer bg-white border-0">

                            <div class="d-grid gap-2">

                                <a href="/matches/<%= item.id %>"
                                   class="btn btn-success">

                                    <i class="bi bi-search-heart"></i>

                                    View Matches

                                </a>

                                <a href="/edit-lost/<%= item.id %>"
                                   class="btn btn-warning">

                                    <i class="bi bi-pencil-square"></i>

                                    Edit

                                </a>

                                <a href="/delete-lost/<%= item.id %>"
                                   class="btn btn-danger"
                                   onclick="return confirm('Delete this item?')">

                                    <i class="bi bi-trash-fill"></i>

                                    Delete

                                </a>

                            </div>

                        </div>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } %>

</div>

<%- include("partials/footer") %>