<%- include("partials/header") %>

<%- include("partials/navbar") %>

<div class="container">

    <form action="/search-lost" method="GET">

        <input
            class="form-control"
            type="text"
            name="keyword"
            value="<%= typeof keyword !== 'undefined' ? keyword : '' %>"
            placeholder="Search by item name, category or location"
        >

        <br>

        <button class="btn-submit">
            Search
        </button>

        &nbsp;

        <a class="btn-primary" href="/lost-items">
            Clear
        </a>

    </form>

    <br>

    <h1>Lost Items</h1>

    <a class="btn-primary" href="/add-lost">
        + Report Lost Item
    </a>

    <br><br>

    <% if(items.length === 0){ %>

        <h3>No Lost Items Found</h3>

    <% } else { %>

        <% items.forEach(item => { %>

            <div class="feature-card">

                <img
                    src="/uploads/<%= item.image %>"
                    alt="Item Image"
                    class="item-image"
                >

                <h2><%= item.title %></h2>

                <p>
                    <strong>Category:</strong>
                    <%= item.category %>
                </p>

                <p>
                    <strong>Description:</strong>
                    <%= item.description %>
                </p>

                <p>
                    <strong>Location:</strong>
                    <%= item.location %>
                </p>

                <p>
                    <strong>Status:</strong>
                    <%= item.status %>
                </p>

                <p>
                    <strong>Reported By:</strong>
                    <%= item.full_name %>
                </p>

                <br>

                <a class="btn-primary" href="/edit-lost/<%= item.id %>">
                    Edit
                </a>

                &nbsp;

                <a class="btn-primary" href="/matches/<%= item.id %>">
                    View Matches
                </a>

                &nbsp;

                <a class="btn-primary" href="/delete-lost/<%= item.id %>">
                    Delete
                </a>

            </div>

            <br>

        <% }) %>

    <% } %>

</div>

<%- include("partials/footer") %>