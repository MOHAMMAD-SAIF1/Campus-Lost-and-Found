<%- include("partials/header") %>

<%- include("partials/navbar") %>

<div class="container py-5">

    <div class="text-center mb-5">

        <h1 class="fw-bold">
            🤖 Smart Match Results
        </h1>

        <p class="text-muted">
            Our intelligent matching system has analyzed possible found items.
        </p>

    </div>

    <!-- Lost Item -->

    <div class="card shadow border-0 mb-5">

        <div class="card-header bg-danger text-white">

            <h3>🔴 Lost Item</h3>

        </div>

        <div class="card-body">

            <h3 class="fw-bold">
                <%= lostItem.title %>
            </h3>

            <p>
                <strong>Category:</strong>
                <span class="badge bg-primary">
                    <%= lostItem.category %>
                </span>
            </p>

            <p>
                <strong>Location:</strong>
                <%= lostItem.location %>
            </p>

            <p>
                <strong>Description:</strong>
                <%= lostItem.description %>
            </p>

        </div>

    </div>

    <h2 class="mb-4">
        🎯 Matching Found Items
    </h2>

    <% if(matches.length===0){ %>

        <div class="alert alert-warning">

            No matching items were found.

        </div>

    <% } else { %>

        <div class="row">

            <% matches.forEach(item=>{ %>

                <div class="col-lg-6 mb-4">

                    <div class="card shadow border-0 h-100">

                        <% if(item.image){ %>

                            <img
                                src="/uploads/<%= item.image %>"
                                class="card-img-top"
                                style="height:250px;object-fit:cover;"
                                alt="Found Item">

                        <% } %>

                        <div class="card-body">

                            <h3 class="fw-bold">

                                <%= item.title %>

                            </h3>

                            <p>

                                <span class="badge bg-success">

                                    <%= item.category %>

                                </span>

                            </p>

                            <p>

                                <strong>📍 Location:</strong>

                                <%= item.location %>

                            </p>

                            <p>

                                <strong>📝 Description:</strong>

                                <%= item.description %>

                            </p>

                            <hr>

                            <h5>

                                🤖 Smart Match Score

                            </h5>

                            <% if(item.matchScore>=90){ %>

                                <span class="badge bg-success fs-6">

                                    ⭐ <%= item.matchScore %>% • Excellent Match

                                </span>

                            <% }else if(item.matchScore>=70){ %>

                                <span class="badge bg-primary fs-6">

                                    ⭐ <%= item.matchScore %>% • Good Match

                                </span>

                            <% }else if(item.matchScore>=50){ %>

                                <span class="badge bg-warning text-dark fs-6">

                                    ⭐ <%= item.matchScore %>% • Average Match

                                </span>

                            <% }else{ %>

                                <span class="badge bg-danger fs-6">

                                    ⭐ <%= item.matchScore %>% • Low Match

                                </span>

                            <% } %>

                            <br><br>

                            <div class="progress" style="height:25px;">

                                <div

                                    class="progress-bar bg-success progress-bar-striped progress-bar-animated"

                                    role="progressbar"

                                    style="width:<%= item.matchScore %>%">

                                    <%= item.matchScore %>%

                                </div>

                            </div>

                            <br>

                            <div class="alert alert-info">

                                <strong>🤖 AI Explanation</strong>

                                <ul class="mb-0">

                                    <% if(item.category===lostItem.category){ %>

                                        <li>✅ Same category detected</li>

                                    <% } %>

                                    <% if(item.location.toLowerCase().includes(lostItem.location.toLowerCase()) || lostItem.location.toLowerCase().includes(item.location.toLowerCase())){ %>

                                        <li>✅ Similar location found</li>

                                    <% } %>

                                    <li>✅ Title similarity analyzed</li>

                                    <li>📊 Overall confidence based on available information</li>

                                </ul>

                            </div>

                        </div>

                        <div class="card-footer bg-white border-0">

                            <div class="d-grid gap-2">

                                <a

                                    href="/chat/<%= item.user_id %>"

                                    class="btn btn-success">

                                    💬 Contact Finder

                                </a>

                            </div>

                            <br>

                            <form action="/submit-claim" method="POST">

                                <input
                                    type="hidden"
                                    name="lost_item_id"
                                    value="<%= lostItem.id %>">

                                <input
                                    type="hidden"
                                    name="found_item_id"
                                    value="<%= item.id %>">

                                <input
                                    type="hidden"
                                    name="finder_id"
                                    value="<%= item.user_id %>">

                                <label class="fw-bold">

                                    Explain why this item belongs to you

                                </label>

                                <textarea

                                    class="form-control"

                                    name="proof"

                                    rows="4"

                                    required

                                    placeholder="Provide identifying details such as color, scratches, stickers, serial number, or any unique marks."></textarea>

                                <br>

                                <button

                                    class="btn btn-primary w-100"

                                    type="submit">

                                    📨 Submit Claim Request

                                </button>

                            </form>

                        </div>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } %>

</div>

<%- include("partials/footer") %>